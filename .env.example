# ============================================================
#   RENTCAR EC — BACKEND .env.example
#   Copia este archivo como .env y completa los valores reales.
#   NUNCA subas el .env con credenciales reales al repositorio.
# ============================================================

# ── Base de datos PostgreSQL ─────────────────────────────────
# Opción A: Supabase (usa ambas URLs — una para runtime y otra para migraciones)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Opción B: Render PostgreSQL / Neon / local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/rentcar_db"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/rentcar_db"

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# NODE_ENV=production  # en despliegue

# ── JWT ───────────────────────────────────────────────────────
# Genera un secreto fuerte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_real_de_al_menos_64_caracteres

# ── CORS ─────────────────────────────────────────────────────
# Orígenes permitidos separados por coma.
# En desarrollo: incluye los puertos de Vite (5173, 5174, etc.)
# En producción: sólo el dominio real del frontend
CORS_ORIGIN=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173
# CORS_ORIGIN=https://tu-frontend.vercel.app  # producción